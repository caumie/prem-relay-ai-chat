{
	"name": "prem-relay-ai-chat",
	"dockerComposeFile": [
		"compose.yml"
	],
	"service": "app",
	"workspaceFolder": "/workspaces/chat",
	"forwardPorts": [8000],
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"openai.chatgpt",
				"esbenp.prettier-vscode",
				"ms-python.black-formatter",
				"ms-python.isort"
			],
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python"
			}
		}
	}
}
